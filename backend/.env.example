# backend/.env.example
# Copy this file to .env and fill in real values. Never commit .env.

# Primary AI - Groq (fast, generous free tier)
GROQ_API_KEY=gsk_your_key_here

# Fallback AI - Google Gemini
GEMINI_API_KEY=AIzaSy_your_key_here

# Database
# Local dev default: sqlite:///./nerdforge.db
# Railway Postgres: use the DATABASE_URL Railway injects automatically
# (Railway may give a "postgres://" URL - the app normalizes this for you)
DATABASE_URL=sqlite:///./nerdforge.db

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Application
DEBUG=True
SECRET_KEY=change-me-in-production

# Railway injects PORT automatically - no need to set locally
PORT=8000
